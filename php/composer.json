{
    "name": "misarai/misarmail-php",
    "description": "Official PHP SDK for MisarMail — full API coverage",
    "type": "library",
    "license": "MIT",
    "homepage": "https://mail.misar.io",
    "keywords": ["misarmail", "email", "sdk", "php", "transactional", "marketing"],
    "authors": [
        {
            "name": "Misar AI",
            "email": "hello@misar.io"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MisarMail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MisarMail\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests/"
    }
}
