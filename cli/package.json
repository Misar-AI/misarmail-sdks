{
  "name": "@misarmail/cli",
  "version": "1.0.0",
  "description": "Official CLI for MisarMail API — send emails, manage contacts, campaigns and more",
  "bin": { "misarmail": "./dist/cli.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["misarmail", "email", "cli", "command-line"],
  "author": "Misar AI <hello@misar.io>",
